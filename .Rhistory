F1<-function(x){0.02*x^2}
F2<-function(x){0.4*x-0.02*x^2}
F1(5)- F1(2) + F2(6) - F2(5)
F1(1)- F1(0)
F2(10)-F2(8)
F3<-function(x){0.04*x^3/3}
F4a-function(x){0.2*x^2 - 0.04*x^3/3}
F4<-function(x){0.2*x^2 - 0.04*x^3/3}
F3(5) - F3(0) + F4(10) - F4(5)
F22<-function(x){0.2+F2(x)}
F22<-function(x){-0.02*x^2+0.4*x-1.3}
F22(7)
F22(7) - F1(1)
F22(6)
F22<-function(x){-0.02*x^2+0.4*x-1}
F22(7)
1-F22(6)
F22(6)
