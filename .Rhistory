n=100
set.seed(23)
times=EnvStats::rtri(n,min=0, max=100, mode=20)
app=as.numeric(runif(n)>=0.4)
a=2; b1=0.8; b2=0.02
no=a+b1*app+b2*times+0.1*rnorm(n) # average of 6 months
##example orders and usage ziehungbestKov
#vals<-seq(1,6)
#probs<-c(0.1,0.15,0.25,0.25,0.15,0.1)
#sum(vals*probs)
#sqrt(sum(vals^2*probs) - (sum(vals*probs))^2)/sqrt(6)
#mean(no) #real mean 3.5
#sd(no) # real sd 1.431782/sqrt(6)
norders<-no
df<-data.frame(norders,app)
write.csv(df, file="norders.csv")
mod<-lm(norders~app)
out<-summary(mod)
n=100
set.seed(23)
times=EnvStats::rtri(n,min=0, max=100, mode=20)
app=as.numeric(runif(n)>=0.4)
a=2; b1=0.8; b2=0.02
no=a+b1*app+b2*times+0.1*rnorm(n) # average of 6 months
##example orders and usage ziehungbestKov
#vals<-seq(1,6)
#probs<-c(0.1,0.15,0.25,0.25,0.15,0.1)
#sum(vals*probs)
#sqrt(sum(vals^2*probs) - (sum(vals*probs))^2)/sqrt(6)
#mean(no) #real mean 3.5
#sd(no) # real sd 1.431782/sqrt(6)
norders<-no
df<-data.frame(norders,app,times)
write.csv(df, file="norders.csv")
mod<-lm(norders~app)
out<-summary(mod)
